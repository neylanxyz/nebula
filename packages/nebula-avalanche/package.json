{
  "name": "@neylanxyz/nebula-avalanche",
  "version": "0.1.0",
  "description": "TypeScript SDK for Nebula privacy pool on Avalanche Fuji testnet",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@neylanxyz/nebula": "workspace:*"
  },
  "peerDependencies": {
    "@aztec/bb.js": "3.0.0-nightly.20251104",
    "@noir-lang/acvm_js": "1.0.0-beta.17",
    "@noir-lang/noir_js": "1.0.0-beta.17",
    "@noir-lang/noirc_abi": "1.0.0-beta.17",
    "viem": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@noir-lang/noir_js": {
      "optional": true
    },
    "@noir-lang/acvm_js": {
      "optional": true
    },
    "@noir-lang/noirc_abi": {
      "optional": true
    },
    "@aztec/bb.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aztec/bb.js": "3.0.0-nightly.20251104",
    "@noir-lang/acvm_js": "1.0.0-beta.17",
    "@noir-lang/noir_js": "1.0.0-beta.17",
    "@noir-lang/noirc_abi": "1.0.0-beta.17",
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "viem": "^2.43.5",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neylanxyz/nebula"
  }
}
